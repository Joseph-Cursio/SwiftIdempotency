--- /dev/null
+++ b/Sources/HelloVapor/Handlers/CreateAcronymHandler.swift
@@ -0,0 +1,13 @@
+import Fluent
+import Vapor
+import SwiftIdempotency
+
+@ExternallyIdempotent(by: "idempotencyKey")
+func createAcronym(
+    req: Request,
+    acronym: Acronym,
+    idempotencyKey: IdempotencyKey
+) async throws -> Acronym {
+    try await acronym.save(on: req.db)
+    return acronym
+}
